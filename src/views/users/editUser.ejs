<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit User</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 24px; }
        .form-row { margin-bottom: 12px; }
        label { display: block; margin-bottom: 6px; }
        input { width: 100%; max-width: 420px; padding: 6px 8px; }
        .actions { margin-top: 16px; }
        .actions a { margin-left: 12px; }
    </style>
</head>
<body>
    <h1>Edit User</h1>

    <% if (!data || !data._id) { %>
        <p>User not found.</p>
    <% } else { %>
        <form action="/put-crud" method="post">
            <input type="hidden" name="id" value="<%= data._id %>">

            <div class="form-row">
                <label for="email">Email</label>
                <input id="email" name="email" type="email" value="<%= data.email %>" readonly>
            </div>

            <div class="form-row">
                <label for="firstName">First Name</label>
                <input id="firstName" name="firstName" type="text" value="<%= data.firstName %>">
            </div>

            <div class="form-row">
                <label for="lastName">Last Name</label>
                <input id="lastName" name="lastName" type="text" value="<%= data.lastName %>">
            </div>

            <div class="form-row">
                <label for="address">Address</label>
                <input id="address" name="address" type="text" value="<%= data.address %>">
            </div>

            <div class="actions">
                <button type="submit">Save</button>
                <a href="/get-crud">Back to list</a>
            </div>
        </form>
    <% } %>
</body>
</html>
